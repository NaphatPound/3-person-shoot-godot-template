; Engine configuration file.
; Third-Person Shooter (Aim & Shoot) 3D Template — see info.md / plan.md / logs.md
;
; Reconfigured from NaphatPound/godot-starter-pack:
;   - renderer switched Forward+ / d3d12  ->  GL Compatibility (required for Web/WebGL2)
;   - main scene, window size, and an input-action autoload added
;   - Jolt physics kept (built-in in 4.6)

config_version=5

[application]

config/name="Third-Person Shooter Template"
run/main_scene="res://scenes/world.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

GameInput="*res://scripts/game_input.gd"
ItemDB="*res://scripts/systems/item_db.gd"
Inventory="*res://scripts/systems/inventory.gd"
InventoryUI="*res://scripts/ui/inventory_ui.gd"
SurvivalStats="*res://scripts/systems/survival_stats.gd"
SurvivalHUD="*res://scripts/ui/survival_hud.gd"
InteractPrompt="*res://scripts/ui/interact_prompt.gd"
Interaction="*res://scripts/systems/interaction.gd"
Currency="*res://scripts/systems/currency.gd"
Merchant="*res://scripts/systems/merchant.gd"
MerchantUI="*res://scripts/ui/merchant_ui.gd"
Weapons="*res://scripts/systems/weapons.gd"
WeaponUI="*res://scripts/ui/weapon_ui.gd"
Quests="*res://scripts/systems/quests.gd"
QuestTracker="*res://scripts/ui/quest_tracker.gd"
Crafting="*res://scripts/systems/crafting.gd"
CraftingUI="*res://scripts/ui/crafting_ui.gd"
Ammo="*res://scripts/systems/ammo.gd"
AmmoHUD="*res://scripts/ui/ammo_hud.gd"
SaveSystem="*res://scripts/systems/save_system.gd"
SaveToast="*res://scripts/ui/save_toast.gd"
DayNight="*res://scripts/systems/day_night.gd"
Horde="*res://scripts/systems/horde.gd"
WorldClockHUD="*res://scripts/ui/world_clock_hud.gd"
Infection="*res://scripts/systems/infection.gd"
InfectionHUD="*res://scripts/ui/infection_hud.gd"
Stamina="*res://scripts/systems/stamina.gd"
StaminaHUD="*res://scripts/ui/stamina_hud.gd"
Storage="*res://scripts/systems/storage.gd"
StorageUI="*res://scripts/ui/storage_ui.gd"
Traps="*res://scripts/systems/traps.gd"
TrapsHUD="*res://scripts/ui/traps_hud.gd"
Minimap="*res://scripts/ui/minimap.gd"
Weather="*res://scripts/systems/weather.gd"
WeatherFX="*res://scripts/ui/weather_fx.gd"
Companions="*res://scripts/systems/companions.gd"
CompanionHUD="*res://scripts/ui/companion_hud.gd"
Stats="*res://scripts/systems/stats.gd"
StatsUI="*res://scripts/ui/stats_ui.gd"
NoiseMeter="*res://scripts/systems/noise.gd"
NoiseHUD="*res://scripts/ui/noise_hud.gd"
Barricades="*res://scripts/systems/barricades.gd"
BarricadesHUD="*res://scripts/ui/barricades_hud.gd"
Difficulty="*res://scripts/systems/difficulty.gd"
DifficultyHUD="*res://scripts/ui/difficulty_hud.gd"
Grenades="*res://scripts/systems/grenades.gd"
GrenadesHUD="*res://scripts/ui/grenades_hud.gd"
Flashlight="*res://scripts/systems/flashlight.gd"
FlashlightHUD="*res://scripts/ui/flashlight_hud.gd"
Perks="*res://scripts/systems/perks.gd"
PerksUI="*res://scripts/ui/perks_ui.gd"
Events="*res://scripts/systems/events.gd"
EventsBanner="*res://scripts/ui/events_banner.gd"
HelpOverlay="*res://scripts/ui/help_overlay.gd"
Crates="*res://scripts/systems/crates.gd"
CratesToast="*res://scripts/ui/crates_toast.gd"
Molotovs="*res://scripts/systems/molotovs.gd"
MolotovsHUD="*res://scripts/ui/molotovs_hud.gd"
Extraction="*res://scripts/systems/extraction.gd"
ExtractionHUD="*res://scripts/ui/extraction_hud.gd"
SaveExtra="*res://scripts/systems/save_extra.gd"
Headshots="*res://scripts/systems/headshots.gd"
HeadshotToast="*res://scripts/ui/headshot_toast.gd"
Bloodstains="*res://scripts/systems/bloodstains.gd"
Tension="*res://scripts/systems/tension.gd"
TensionFX="*res://scripts/ui/tension_fx.gd"
Variants="*res://scripts/systems/variants.gd"
Score="*res://scripts/systems/score.gd"
ScoreHUD="*res://scripts/ui/score_hud.gd"
PauseMenu="*res://scripts/ui/pause_menu.gd"
Market="*res://scripts/systems/market.gd"
MarketToast="*res://scripts/ui/market_toast.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
textures/vram_compression/import_etc2_astc=true
